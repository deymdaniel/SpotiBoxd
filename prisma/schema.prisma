// This is the SpotiBoxd Prisma schema file.
// It defines 5 related tables for Users, Albums, Reviews, Favorites, and ListenList items.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model represents a registered site user (either USER or ADMIN)
model User {
  id           String       @id @default(uuid())
  email        String       @unique
  username     String       @unique
  passwordHash String
  role         String       @default("USER") // "USER" or "ADMIN"
  createdAt    DateTime     @default(now())
  
  reviews      Review[]
  favorites    Favorite[]
  listenList   ListenList[]
}

// Album model stores the local cache of albums searched or interacted with
model Album {
  id         String       @id @default(uuid())
  lastFmId   String       @unique // Unique identifier from Last.fm API
  title      String
  artist     String
  coverUrl   String
  createdAt  DateTime     @default(now())
  
  reviews    Review[]
  favorites  Favorite[]
  listenList ListenList[]
}

// Review model stores user ratings (1-5 stars) and comments on albums
model Review {
  id        String   @id @default(uuid())
  userId    String
  albumId   String
  rating    Float    // Rating between 1.0 and 5.0 (stars)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

// Favorite model tracks a user's favorited albums
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  albumId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId]) // A user can only favorite an album once
}

// ListenList model acts as a watchlist for albums a user intends to listen to
model ListenList {
  id        String   @id @default(uuid())
  userId    String
  albumId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId]) // A user can only add an album once to their ListenList
}
